# Define header lines to be preserved or discarded, globally, i.e.
# for all lists and listproc. Lines that start with ! are to be discarded.
# Here is a list of those headers, which some mailers use, which are
# included in this example file that should be removed from messages:
# 
#    Delivery-Receipt-To:   undisclosed mailer
#    Disposition-notification-to:  Eudora Pro 4.0/4.1
#    Disposition-Notification-To:  Microsoft Outlook 8.5, Build 4.71.2173.0
#    Read-Receipt-To:       undisclosed mailer
#    Read-receipt-to:       Simeon for Windows Version 4.1
#    Return-Receipt-To:     Microsoft Exchange / Internet Mail Service
#    Return-receipt-to:     Pegasus Mail for Win32 (v2.53/R1)
#    X-Acknowledge-To:      undisclosed mailer
#    X-Confirm-Reading-To:  Pegasus Mail for Win32 (v2.53/R1)
#    X-PMrqc:               Pegasus Mail
#    X-pmrqc:               Pegasus Mail for Win32 (v2.53/R1)
# 
header * {
  !Delivery-Receipt-To:
  !Disposition-[N,n]otification-[T,t]o:
  !Pmrc:
  !Registered-Mail-Reply-Requested-By:
  !Read-[R,r]eceipt-[T,t]o:
  !Return-[R,r]eceipt-[T,t]o:
  !X-Acknowledge-To:
  !X-Confirm-[R,r]eading-[T,t]o:
  !X-Phone:
  !X-[P,p][M,m]rqc:
}

