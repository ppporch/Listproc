######################################################################
#
#  Organizational information & required options
#
######################################################################


#
# Define your organization.  This is a simple text string that will be used
# in ListProc's informational messages to tell users which server they 
# are interacting with.
#
organization Name of Your Organization

#
# Define the ListProc's name (Used as a comment in the From: line of
# messages from the ListProc server):
#
comment server "CREN ListProc(tm) Version 8.2"

#
# Define the system's manager address.  This should be the address of
# a real person who will be responsible for maintaining the ListProc
# server.  This user will have the power to use all of ListProc's
# commands on all lists and archives at all times.  In addition,
# ListProc will send any emergency warning messages to this address.
#
manager somebody@your.host.name

#
# Define the manager password for this installation.  The manager can
# use this password on all ListProc commands that require a password -
# but only when they are sending mail from their own address.  Please
# note that this password IS case-sensitive.
#
password hardtoguess

#
# Define your server's email address and optional command line arguments:
#
server listproc@your.host.name your.host.name	# -b get

#
# Define the server daemon's (serverd) command line options.
#
# -i <timeout>		instructs serverd to allow interactive sessions
#			and sets the timeout value (in seconds) for total
#			session length
#
# -p <port>         	use the specified port for interactive sessions (the 
#			default is 372); using a non-priviledged port like
#			1800 is recommended (that way you don't have to run
#			serverd setuid root), although then you must specify
#			the port when you start the ilp client
#
# -c <max>		defines the maximum number of simultaneous 
#			interactive sessions.  The default is unlimited
#
# -l <num>		instructs ListProc to stop spawning new processes
#			(ie forking new threads) if the system load gets
#			above the specified value
#
#serverd -i 1800 -p 1800 -c 10 -l 3

serverd

#
# Define the user as whom ListProc should run.  This prevents
# accidental changes to file ownership and permissions by starting
# ListProc as root.  
#
user listprocuser


#
# Define the umask which defines the file permissions ListProc
# uses when creating and modifying files.  Its very important for
# security that this umask remains at either 077, 027, or 007.
# Please recall that the following is true:
# umask:  file permissions:    meaning:
# 077     700                  only the user can read/write/execute the files
# 027     750                  user=read/write/execute group=read/execute
# 007     770                  user=read/write/execute group=read/write/execute
# Do NOT allow "other" to have any permissions over these files for security
# reasons (e.g. anyone who can log in can find out your list passwords)
#
#umask 077
#umask 027

#
# Define the umask which will be used for the list archives.
# This variable establishes separate file permissions for the ListProc 
# archives directories and files. This mask affects only the archives. 
# If you plan to allow anonymous ftp, gopher or plain-text http 
# access to the archives, then you should use a mask of 022, otherwise, 
# the 077 mask for archives should be sufficient.
# umask:  file permissions:    meaning:
# 077     700                  only the user can read/write/execute the files
# 022     755                  user=r/w/x group=r/x other=r/x
#
#archives_umask 077
#archives_umask 022


######################################################################
#
#  Mail delivery options
#
######################################################################


# Tell the system how to send mail. "system" is the recommended method:
mailmethod system
# mailmethod sendmail /usr/lib/sendmail -ba
# mailmethod sendmail /usr/ucblib/sendmail -ba
# mailmethod sendmail /usr/lib/sendmail -t (IDA)

#
# Define the host to connect for sending mail, and an optional port.
# This may be a fully qualified domain name or IP address.
# If no host is defined, "localhost" is used.  The default port is 25.
#
# mta_host your.host.name
# mta_host 127.0.0.1 2000
mta_host 127.0.0.1

#
# Set SMTP HELO argument.  Some MTA's require uses to use an
# appropriate argument to the SMTP HELO command.  If your MTA rejects
# messages due to a bad HELO argument, set this to the name of your
# host.
#
helo_arg localhost

#
# Turn on BSD_MAIL and define the path to it.  This is sometimes used
# by ListProc as a last-ditch mechanism for sending out emergency
# warning messages.  Some common options are listed below.
#
#ucb_mail /bin/mailx
#ucb_mail /usr/bin/mailx
#ucb_mail /bin/Mail
#ucb_mail /usr/ucb/Mail # Solaris



######################################################################
#
#  Performance-related options
#
######################################################################


# Tell the daemon how often to check for mail or requests (in seconds); if the
# first arg is 0 (look for mail all the time), a sleep time can be specified
# so that serverd will rest at the of the scan of all lists (to reduce CPU
# usage):
#frequency 5
frequency 0 15

# Define the maximum number of processes to be forked for list mail
# distribution; default is 1; max is 255
threads for_list_mail 15

# Define the maximum number of processes to be forked for processing email
# requests; default is 1; max is 255
threads for_mail_requests 5

# Tell the server how many recipients to pack together in a single message:
multiple_recipients 30

# Define global limits:
limit message 65536	# reject messages longer than 65536 bytes (64 KB)
limit files 65536	# split files longer than 65536 bytes (64 KB)

# Define the maximum number of lines in the message id and checksum files
# (default is 2000):
max_file_length 2000




######################################################################
#
#  General options
#
######################################################################

#
# Define how and where the logs should be kept.  There are several
# options to this directive:
#
#  file [logfile]  Log messages are saved to the specified file.  If
#                  no file is specified, messages are written to
#                  "listproc.log" in the ListProc installation
#                  directory.  This is the default.
#
#  individual      individual log files are kept for each ListProc
#                  binary, with names such as ".report.PROGRAM" (where
#                  PROGRAM is the name of the program).  Older
#                  messages from these logs are placed in
#                  ".rep.PROGRAM.acc" each time ListProc restarts.
#
#  old_style       This keeps individual log files as with the
#                  "individual" option.  In addition, the log files
#                  include timestamp information on the line after the
#                  actual message.  This is available for sites that
#                  have pre-existing utilities that parse this older
#                  style of log file.  In general, this format is less
#                  useful than the others, and we discourage its use.
#
#  syslog <FACIL>  This instructs ListProc to send log messages to the
#                  specified syslog facility.  Common choices for the
#                  facility are LOG_DAEMON, LOG_MAIL, LOG_USER and
#                  LOG_LOCAL0 through LOG_LOCAL7
#
# Examples:
#
# log file /var/log/listproc
# log syslog LOG_LOCAL7
#

# (Note: for compatibility the "syslog" config file directive can
# still be used to specify syslog logging.  However, the "log"
# directive should be used instead for new installations.



# Tell the daemon how often to process archives and perform AFD/FUI:
# deliver_files frequency [when]
# deliver_files hourly 30		# Deliver hourly on the half mark
deliver_files daily 8:30	# Deliver every day at 8:30 am
# deliver_files weekly Monday	# Deliver every week on Mondays
# deliver_files monthly		# Deliver the first day of every month

#
# Define the default archive directory for lists.  The default is
# $LPDIR/archives/list-alias):
#
#default_arch_dir /ftp/mailing-lists

# NOTE: as of May 1999 the global server is down, and it may never be
# re-established.  So for now the following two items should remain
# commented out.  - Harold

# Define the global query server for all lists worldwide.  If you
# don't want your server to forward requests for unknown lists,
# comment out this line.  Otherwise, you should leave it as-is.
#
#global-query-server listproc@listproc.listproc.net listproc.listproc.net 372

# Define the master server for collecting global list information, and
# the time to send a list of published lists daily.  Comment this out
# if you don't want your server to notify the global server about your
# published lists.  Otherwise, this should be left as-is.
#
#global-update-server global-update-server@listproc.listproc.net 04:00

# Define the contents of the Precedence: header line.
# If not defined, no Precedence: line is added:
#precedence bulk  # Usually bulk, junk, first-class or none

# Tell the server when to batch requests:
batch 8 20	 # batch requests between 8 am and 8 pm

# Tell the server about certain restrictions:
#restriction 4	 # certain requests may not be serviced above this # of users

# If posting to newsgroups, define where inews resides.  
# The default is /usr/lib/news/inews:
# inews /usr/bin/inews

# Define system-wide options:
#option post_mail # Post to news; other choice is gate_mail
option gate_mail
#option ignore_invalid_requests	# Ignore a request if it cannot be recognized
#option relaxed_syntax		# Ignore extra arguments to requests
#option multiple_listprocs	# For sites running 2 or more copies

# Highly recommended---a bad subscribers file can take down ListProc
option readonly_subscribers_files # Disable PUT ... SUBSCRIBERS by owners

# The following determines what kind of MIME digests are to be distributed;
# if the option below is defined, the system sends multipart/digest MIME
# digests where the preamble is a plain/text message and dashes are used for
# separators according to RFC 1153 (this RFC is experimental); otherwise, the
# default behavior is to send multipart/mixed with embedded multipart/digest
# MIME digests; we do not recommend the definition of this option.
#option rfc1153_compliant_digests	

# Define the expiration period of confirmation cookies (in days) -- default 7:
conf_cookie_expiration 7


#
# Global Filter Program allows sites to include customizable message 
# footers, editorial notes, or other information.  This option  
# defines the path to a default filter program.  This will be used
# by all lists that (1) don't have their own filter program defined
# and (2) aren't specifically configured to NOT use a filter
# program.  The filter program can be given either a full path or a
# path relative to the ListProc installation directory.
#
#global_filter_prog /path/to/program --arg1 value --arg2 value
#global_filter_prog support/add_footer


# Web Archive
# Define an external program to add a message to a web archive.
# This will be used by all lists that (1) don't have their own web
# archive program defined and (2) aren't specifically configured
# to NOT use a web archive program.  The filter program can be
# given either a full path or a path relative to the ListProc
# installation directory.
#
#global_web_archive_prog /path/to/lp-web/utils/add_to_archive





