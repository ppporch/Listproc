# Define blackout addresses (regular expressions):
#
# If you need to allow a certain address which is blacked out
# currently, such as you wanted to allow mail from admin@machine.org,
# then you could put this at the end of this definition:
# 
#	&~admin@machine.org
# 
# This will cause the regular expression to match everything it did
# before EXCEPT that specific user address.
#mailer_daemon '[ 	]*test$|^uucp|mrgate|mmdf|^smt.*|^mal@|^admin|^root|&
#majordomo&~admin@machine.org'
mailer_daemon '[ 	]*test$|^uucp|mrgate|mmdf|^smt.*|^mal@|^admin|^root|&
majordomo'

# Define blackout subjects (regular expressions -- notice the & continuation
# character which is supported throughout the config file):
#susp_subject 'remove[ 	]+me|remove[ 	]+my|&
#delete[ 	]+me|delete[ 	]+my|add[ 	]+me|add[ 	]+my|&
#^[ 	]*test[ 	]*$|^[ 	]*test.+ignore|please[ 	]+ignore|&
#Confirmation[ 	]+of[ 	]+your[ 	]+message|Receipt[ 	]+Confirmation|&
#RCPT:|Confirm:[ 	]|Important[	 ]+message[ 	]+from|&
#Fwd:[ 	]+Workbook[ 	]+from[ 	]+all.net[ 	]+and[ 	]+Fred[ 	]+Cohen'


# Turn on error analysis, set level and grace period (in seconds):
# The level may be either 1 (scan for a few errors) or 9 (scan for all
# errors).  The grace period is the number of seconds to look for 2
# bounces.  If 2 bounces occur during the grace period, and the list
# is auto-delete-subscribers, then the email address will be removed from
# the list.  The example scans for all errors which occurs in 72 hours.
#
# note: as of 8.2.08 the grace period does not work; if you turn on
# auto-delete-subscribers and the code works for the bounce message,
# the user will get deleted immediately; this is expected to be fixed
# in 8.3
#
error_analysis 9 259200
# 

# Override defaults for address validation for subscriptions
#
# Badly formatted addresses will be refused; the commented items
# below are the defaults; uncomment and adjust as you need to.  Note
# that these strings are delemited by periods instead of single quotes,
# since periods are always valid characters
#
# the part before the @
#address_illegal_local .()<>,;\[]" |{}@.
#
# the part after the @
#address_illegal_domain .()<>,;:\[]"' |{}.
#
# Also, while the system defaults to requiring a "fully_qualified" domain
# (actually, just something after the @ with at least one period), the
# directive address_domain_required allows you to relax that with one
# of two options:
#
# do not require a domain (allow local machine addresses)
#address_domain_required no
#
# do not require the full domain (i.e. foo@bar, instead of foo@bar.net)
#address_domain_required machine


# Ignore these extra requests (regular expressions); check
#
# http://www.cren.net/listproc/docs/manager-faq.html#ignore_requests
#
# for the current version of a regex that takes care of common free mail
