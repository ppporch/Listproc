#-*-makefile-*-
#
# For SCO Openserver 5.0.6A

# make sure not to put any whitespace before or after the value below
LP_PORTNAME=sco-openserver-5.0.6A

# Sleepycat Definitions

# see dbm/build_unix.html and dbm/Makefile for details as to how to
# set this if you need to force database compilation to be different
# than the default that configure decides upon

# use env to set one or more environment variables

DB_ENV = env CC=gcc CFLAGS="-O -fno-strict-aliasing" # play it safe for gcc 2.9.5

# set additional configuration options

# Note that the --enable-diagnostic "flag should NOT be defined when
# configuring to build production binaries, as you will lose a significant
# amount of performance" according to the Sleepcat documentation.

#DB_CONF = --enable-diagnostic

# ListProc Definitions

# define your compiler (some source files may need different compiler):
LP_CC = gcc -fwritable-strings -fno-strict-aliasing # play it safe for gcc 2.9.5

# define special symbols (system, preprocessor options, etc):
LP_DEFINES	= -DLP_PORTNAME=\"$(LP_PORTNAME)\" \
		  -DHAVE_ULIMIT_H \
		  -DHAVE_SELECT_H -DHAVE_SETJMP_H \
		  -DBUFFSIZ=10240 -DNO_MTA_REST -DMMAP \
		  -DUSE_CARRIAGE_RETURN_LINEFEED -DNO_LIC \
		  -DSPEED_UP_SUBSCRIBER_LOOKUPS \
		  -Dsco -I/usr/include/netinet

# define the optimization level
LP_OPTIMIZATION	= -O2 # ~~~ later turn on -O

# define where the preprocessor is:
CPP		= /lib/cpp

# define linking options and libraries
LP_LDFLAGS		= $(LP_OPTIMIZATION)
LP_LIBS		= -lsocket -lresolv
LP_MATH_LIB	= -lm


# Define the library creation command
#RANLIB		= ranlib
RANLIB		= ar ts

#SHELL		= /bin/sh
SHELL		= /usr/local/bin/bash

#ECHO_C 		= \c
ECHO_N		= -n #Note the space after the -n.  This is important!!


